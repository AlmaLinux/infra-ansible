# {{ ansible_managed }}

uid = nobody
gid = nobody
reverse lookup = false
forward lookup = false
max connections = {{ almalinux_repo_rsyncd_max_connections }}
transfer logging = true
use chroot = true
read only = true
timeout = 600

motd file = /etc/rsyncmotd

log file=/var/log/rsyncd.log

{% for module, values in almalinux_repo_rsync_modules.items() %}
[{{ module }}]
{% for key, value in values.items() %}
{{ key }} = {{ value }}
{% endfor %}

{% endfor %}
